# ─────────────────────────────────────────────
#  Story Waver — Environment Configuration
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Model name as it appears in `ollama list`
# Options: phi | phi3 | phi3:mini | mistral | llama3.2 | gemma2 etc.
OLLAMA_MODEL=phi
